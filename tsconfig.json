{
  "compilerOptions": {
    // ============================================
    // BÁSICO: Qué versión de JS genera
    // ============================================
    "target": "ES2020",
    "module": "node16",
    "lib": ["ES2020"],

    // ============================================
    // STRICT MODE: Verificaciones estrictas
    // ESTO ES LO MÁS IMPORTANTE DE TypeScript
    // ============================================
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,

    // ============================================
    // MÓDULOS: Cómo resuelve imports
    // ============================================
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    // ============================================
    // CARPETAS: Dónde lee y dónde escribe
    // ============================================
    "outDir": "./dist",
    "rootDir": "./src",

    // ============================================
    // EXTRAS
    // ============================================
    "types": ["node", "jest"], // ← AGREGAR ESTA LÍNEA
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
